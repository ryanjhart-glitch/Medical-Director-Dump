# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# --- Email (Gmail recommended) ---
# Use a Gmail account dedicated to this tool.
# Generate an App Password at: https://myaccount.google.com/apppasswords
# (requires 2-Step Verification to be enabled on the account)
EMAIL_FROM=your-sender@gmail.com
EMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Comma-separated list of addresses to receive the daily report
EMAIL_TO=you@example.com

# Optional: override the email subject line
# EMAIL_SUBJECT=Daily Vet Medical Director Candidates Report

# --- People Data Labs API (optional — free tier: 100 calls/month) ---
# Sign up and get your key at: https://www.peopledatalabs.com/
# Free tier is enough for daily runs. Returns real names, titles, locations, emails.
PDL_API_KEY=your-pdl-api-key-here

# --- Apollo.io API (optional — requires paid plan ~$49/mo) ---
# Get your API key at: https://app.apollo.io/#/settings/integrations/api
# NOTE: Free Apollo plan does NOT include the People Search API.
APOLLO_API_KEY=your-apollo-api-key-here

# --- State Licensing Boards (no key needed) ---
# Florida DBPR veterinary license data is scraped automatically.
# Returns: name + city only (no email/LinkedIn — public record limitation).
